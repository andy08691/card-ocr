# Server bind address
# Use 0.0.0.0 to allow access from other processes on the same machine or local network
HOST=0.0.0.0

# Port — change if 8000 is already in use (e.g. PORT=8080)
PORT=8000

# Directory for storing uploaded card images
MEDIA_DIR=media

# SQLite database path
DATABASE_URL=sqlite:///./card_ocr.db
